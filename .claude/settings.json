{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/inject-prior-state.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/enforce-browse-protocol.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/normalize-research-question.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/post-subagent-worldmodel-check.ts",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-agent-output.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/reinject-state-after-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-stop.ts",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "env": {
    "KOSMOS_PROJECT_ROOT": "/home/palantirkc/kosmos",
    "KOSMOS_RESEARCH_BASE": "/home/palantirkc/.claude/research"
  }
}
