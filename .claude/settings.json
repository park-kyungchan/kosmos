{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/inject-prior-state.ts",
            "timeout": 10,
            "statusMessage": "Loading prior session state..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/pipeline-status-inject.ts",
            "timeout": 5,
            "statusMessage": "Loading pipeline status..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/enforce-browse-protocol.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/normalize-research-question.ts",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/post-subagent-worldmodel-check.ts",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-agent-output.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/enforce-file-ownership.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-task-naming.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/team-phase-gate.ts",
            "timeout": 15,
            "statusMessage": "Validating phase gate..."
          },
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-teammate-comms.ts",
            "timeout": 5,
            "statusMessage": "Verifying downstream notification..."
          },
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/auto-shutdown-completed.ts",
            "timeout": 5,
            "statusMessage": "Checking agent remaining tasks..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/lead-inbox-monitor.ts",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/idle-cost-guard.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "prototyper",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-prototype-stop.ts",
            "timeout": 10,
            "statusMessage": "Validating prototype artifacts..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/reinject-state-after-compact.ts",
            "timeout": 10,
            "statusMessage": "Re-injecting session state..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${KOSMOS_PROJECT_ROOT:-.}/.claude/hooks/validate-stop.ts",
            "timeout": 10,
            "statusMessage": "Validating session completeness..."
          }
        ]
      }
    ]
  },
  "env": {
    "KOSMOS_PROJECT_ROOT": "/home/palantirkc/kosmos",
    "KOSMOS_RESEARCH_BASE": "/home/palantirkc/.claude/research",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
